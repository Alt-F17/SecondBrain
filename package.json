{
  "name": "second-brain",
  "version": "1.0.0",
  "description": "AI-powered personal memory system with semantic search, voice recording, and vector database storage",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --forceExit --runInBand",
    "frontend": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:start": "cd frontend && npm start"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/*.test.js"],
    "setupFilesAfterEnv": [],
    "testTimeout": 15000,
    "collectCoverageFrom": ["server.js"],
    "coverageReporters": ["text", "lcov"]
  },
  "keywords": [
    "memory",
    "ai",
    "vector-database",
    "semantic-search",
    "chroma",
    "nextjs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "chromadb": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^4.20.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
